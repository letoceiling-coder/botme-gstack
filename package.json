{
  "name": "botme",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @botme/database generate",
    "db:migrate": "pnpm --filter @botme/database migrate:dev",
    "db:migrate:deploy": "pnpm --filter @botme/database migrate:deploy",
    "db:push": "pnpm --filter @botme/database push",
    "validate:foundation": "bash infra/validate-foundation.sh",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20"
  }
}
