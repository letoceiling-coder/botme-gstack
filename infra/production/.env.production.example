# Copy to /var/www/agent.neeklo.ru/.env on the server (never commit .env)

NODE_ENV=production

# App URLs (used by API CORS, redirects, widget embed)
API_URL=https://agent.neeklo.ru/api
WEB_URL=https://agent.neeklo.ru
WIDGET_URL=https://agent.neeklo.ru
WIDGET_TRUSTED_PREVIEW_ORIGINS=agent.neeklo.ru,localhost,127.0.0.1
CORS_ORIGINS=https://agent.neeklo.ru

# Ports (PM2 + nginx)
API_PORT=3110
WEB_PORT=4173
WIDGET_PORT=4174

# Database / cache (local on server)
DATABASE_URL=postgresql://botme:botme@127.0.0.1:5432/botme?schema=public
REDIS_URL=redis://127.0.0.1:6379

# Auth — generate strong secrets before deploy
JWT_ACCESS_SECRET=CHANGE_THIS_ACCESS_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_THIS_REFRESH_SECRET_MIN_32_CHARS
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
COOKIE_DOMAIN=.neeklo.ru

# Encryption (API keys at rest) — 64 hex chars
MASTER_ENCRYPTION_KEY=CHANGE_THIS_64_HEX_MASTER_ENCRYPTION_KEY

# S3 / MinIO (project uses S3_* names, not MINIO_*)
S3_ENDPOINT=http://127.0.0.1:9000
S3_PUBLIC_ENDPOINT=https://agent.neeklo.ru/storage
S3_ACCESS_KEY=botme
S3_SECRET_KEY=botme_secret
S3_BUCKET=botme
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Ollama Neeklo (server-side only — do not expose token to frontend)
OLLAMA_NEEKLO_BASE_URL=https://ollama.neeklo.ru/v1
OLLAMA_NEEKLO_TOKEN=

# Frontend build-time (set before pnpm build, or in apps/web/.env.production)
VITE_API_URL=https://agent.neeklo.ru/api
VITE_WS_URL=https://agent.neeklo.ru
