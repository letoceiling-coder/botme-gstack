# Database
DATABASE_URL=postgresql://botme:botme@localhost:5432/botme?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=botme
S3_SECRET_KEY=botme_secret
S3_BUCKET=botme
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Auth
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# Encryption (API keys at rest)
MASTER_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# App URLs
API_URL=http://localhost:3010
WEB_URL=http://localhost:5173
WIDGET_URL=http://localhost:5174
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Ports
API_PORT=3010
WORKER_PORT=3002

# Ollama Neeklo (server-side token; set in production .env only)
OLLAMA_NEEKLO_BASE_URL=https://ollama.neeklo.ru/v1
OLLAMA_NEEKLO_TOKEN=

# Cookie domain for production (e.g. .neeklo.ru); leave empty for localhost
COOKIE_DOMAIN=

# Frontend (Vite) — set in apps/web/.env.production for production builds
VITE_API_URL=http://localhost:3010
VITE_WS_URL=http://localhost:3010
