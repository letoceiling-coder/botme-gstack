# Example nginx for self-hosted operator runtime on your domain
# Replace YOUR_DOMAIN and paths. API/WebSocket proxy to agent.neeklo.ru backend.

server {
    listen 443 ssl http2;
    server_name operators.YOUR_DOMAIN;

    ssl_certificate     /etc/letsencrypt/live/operators.YOUR_DOMAIN/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/operators.YOUR_DOMAIN/privkey.pem;

    root /var/www/operator-runtime;
    index operator.html;

    add_header Permissions-Policy "camera=*, microphone=*, autoplay=*, fullscreen=*, display-capture=*" always;

    location / {
        try_files $uri $uri/ /operator.html;
        add_header Cache-Control "no-cache, must-revalidate" always;
    }

    location /assets/ {
        add_header Cache-Control "public, max-age=31536000, immutable" always;
    }

    # Proxy API to Botme backend (or set BOTME_API_URL to agent.neeklo.ru directly in config.json)
    location /api/ {
        proxy_pass https://agent.neeklo.ru/api/;
        proxy_http_version 1.1;
        proxy_set_header Host agent.neeklo.ru;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /socket.io/ {
        proxy_pass https://agent.neeklo.ru/socket.io/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_set_header Host agent.neeklo.ru;
        proxy_read_timeout 86400;
    }
}
